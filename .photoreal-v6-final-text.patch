+name: Photoreal Craft v6 validation
+
+on:
+  pull_request:
+    branches: [main]
+    paths:
+      - 'next/**'
+      - '.github/workflows/photoreal-craft-v6-ci.yml'
+      - '.github/workflows/deploy-react-v1.yml'
+  workflow_dispatch:
+
+permissions:
+  contents: read
+
+concurrency:
+  group: photoreal-craft-v6-${{ github.event.pull_request.number || github.ref }}
+  cancel-in-progress: true
+
+jobs:
+  iphone-webkit-audit:
+    runs-on: ubuntu-latest
+    timeout-minutes: 45
+    steps:
+      - uses: actions/checkout@v4
+      - uses: actions/setup-node@v4
+        with:
+          node-version: '22'
+          cache: npm
+          cache-dependency-path: next/package-lock.json
+      - name: Install exact dependencies
+        working-directory: next
+        run: npm ci
+      - name: Typecheck, deterministic model audit and production build
+        working-directory: next
+        run: |
+          npm run typecheck
+          npm run test:photoreal:unit
+          npm run build
+          python -m py_compile scripts/visual-audit-v6.py
+      - name: Install iPhone WebKit and image audit tools
+        working-directory: next
+        run: |
+          npx playwright install --with-deps webkit
+          python -m pip install --disable-pip-version-check pillow numpy
+      - name: Start verified production preview
+        working-directory: next
+        run: |
+          setsid npm run preview >/tmp/bonsai-photoreal-v6-preview.log 2>&1 &
+          server=$!
+          echo "$server" >/tmp/bonsai-photoreal-v6-preview.pid
+          for i in $(seq 1 120); do
+            curl -fsS http://127.0.0.1:4173/bonsai-app/ >/dev/null && exit 0
+            sleep .25
+          done
+          cat /tmp/bonsai-photoreal-v6-preview.log
+          exit 1
+      - name: Run 390x844 DPR3 WebKit regressions
+        working-directory: next
+        run: |
+          npm run test:smoke
+          node tests/seasonal-v4.mjs
+          npm run test:photoreal
+      - name: Reject tubes, floating work, bright ribbons and circular markers
+        working-directory: next
+        run: python scripts/visual-audit-v6.py --output photoreal-v6-pr-visual-audit.json
+      - name: Preserve complete audit bundle
+        if: always()
+        uses: actions/upload-artifact@v4
+        with:
+          name: bonsai-photoreal-craft-v6-pr-audit
+          path: |
+            next/test-artifacts
+            /tmp/bonsai-photoreal-v6-preview.log
+          if-no-files-found: error
+          retention-days: 14
+      - name: Stop preview
+        if: always()
+        run: |
+          if test -f /tmp/bonsai-photoreal-v6-preview.pid; then
+            server="$(cat /tmp/bonsai-photoreal-v6-preview.pid)"
+            kill -TERM -- -"$server" 2>/dev/null || kill "$server" 2>/dev/null || true
+          fi
diff --git a/next/scripts/visual-audit-v6.py b/next/scripts/visual-audit-v6.py
