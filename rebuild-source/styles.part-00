:root{font-family:-apple-system,BlinkMacSystemFont,"Hiragino Sans","Yu Gothic",sans-serif;color:#f2ebdc;background:#07100b;font-synthesis:none;text-rendering:optimizeLegibility;--bg:#07100b;--panel:#111d15;--panel-2:#17251b;--line:rgba(255,255,255,.1);--muted:#93a197;--gold:#d6b777;--cream:#f2ebdc;--danger:#a65146}*{box-sizing:border-box}html{background:var(--bg);color-scheme:dark}body{margin:0;background:radial-gradient(circle at 50% 0,#14231a 0,transparent 32%),var(--bg);color:var(--cream);min-height:100vh;min-height:100dvh}button,input{font:inherit}button{cursor:pointer}.app-shell{min-height:100vh;min-height:100dvh;padding-bottom:calc(76px + env(safe-area-inset-bottom));background:linear-gradient(180deg,rgba(16,31,22,.4),transparent 220px)}.topbar{position:sticky;top:0;z-index:20;display:flex;align-items:center;justify-content:space-between;gap:16px;padding:calc(12px + env(safe-area-inset-top)) 16px 12px;background:linear-gradient(180deg,rgba(7,16,11,.98),rgba(7,16,11,.86),transparent);backdrop-filter:blur(10px)}.brand,.onboard-brand{font:25px Georgia,serif;letter-spacing:.26em}.eyebrow{color:var(--muted);font-size:11px;letter-spacing:.05em}.money{font-weight:750;font-size:19px}.app-main{width:min(100%,760px);margin:auto;padding:4px 12px 32px}.page{animation:pageIn .26s ease both}@keyframes pageIn{from{opacity:0;transform:translateY(5px)}to{opacity:1;transform:none}}.page-heading{padding:18px 4px 16px}.page-heading h1{font:34px Georgia,serif;margin:5px 0 8px}.page-heading p{color:var(--muted);font-size:13px;line-height:1.7;margin:0}.tree-tabs{display:flex;gap:7px;overflow:auto;padding:4px 1px 10px;scrollbar-width:none}.tree-tabs button{flex:0 0 auto;border:1px solid var(--line);border-radius:999px;background:rgba(255,255,255,.045);color:#aab5ac;padding:8px 12px;font-size:11px}.tree-tabs button.active{border-color:rgba(214,183,119,.55);color:var(--cream);background:rgba(214,183,119,.1)}.tree-tabs .add-tree{color:var(--gold)}.artwork-card,.show-card{overflow:hidden;border:1px solid var(--line);border-radius:25px;background:linear-gradient(180deg,#16241a,#0d1811);box-shadow:0 22px 55px rgba(0,0,0,.2)}.artwork-head{display:flex;justify-content:space-between;align-items:flex-start;padding:17px 17px 14px}.artwork-head h1{font:31px Georgia,serif;margin:7px 0 5px}.artwork-head p{color:var(--muted);font-size:10px;margin:0}.badge{display:inline-flex;border:1px solid rgba(214,183,119,.36);border-radius:999px;color:#e3c687;padding:5px 8px;font-size:9px}.icon-button{border:1px solid var(--line);border-radius:12px;background:rgba(255,255,255,.04);color:var(--cream);width:39px;height:39px;font-size:20px}.bonsai-stage{position:relative;display:block;width:100%;height:370px;margin:0;overflow:hidden;background:radial-gradient(circle at 50% 28%,#475e4b 0,#1a2a1f 45%,#0a120d 100%);isolation:isolate}.bonsai-photo{width:100%;height:100%;display:block;object-fit:cover;object-position:center 49%;transition:filter .3s ease}.stage-vignette{position:absolute;inset:0;z-index:2;pointer-events:none;background:radial-gradient(circle at 50% 45%,transparent 35%,rgba(3,8,5,.18) 70%,rgba(1,4,2,.7) 100%),linear-gradient(180deg,rgba(255,255,255,.04),transparent 24%,rgba(0,0,0,.35));box-shadow:inset 0 0 0 1px rgba(214,183,119,.1)}.part-visual{position:absolute;z-index:3;width:1px;height:1px}.prune-mask{position:absolute;width:92px;height:58px;transform:translate(-50%,-50%);border-radius:50%;background:radial-gradient(ellipse,rgba(3,10,5,.72),rgba(4,12,7,.18) 58%,transparent 74%);mix-blend-mode:multiply}.condition{position:absolute;width:68px;height:44px;transform:translate(-50%,-50%);border-radius:50%;background:radial-gradient(ellipse,rgba(143,90,45,.7),rgba(93,59,31,.2) 55%,transparent 75%);mix-blend-mode:multiply}.condition-sootyMold{background:radial-gradient(ellipse,rgba(18,16,13,.8),rgba(18,16,13,.18) 58%,transparent 75%)}.condition-rootRot{width:95px;height:32px;background:radial-gradient(ellipse,rgba(64,30,18,.8),rgba(50,24,14,.12) 65%,transparent 78%)}.condition.pest{width:56px;height:42px;background:radial-gradient(circle at 22% 30%,#d5b478 0 2px,transparent 3px),radial-gradient(circle at 62% 48%,#b88d5d 0 2px,transparent 3px),radial-gradient(circ