le at 44% 72%,#d4b47e 0 1.6px,transparent 2.5px)}.condition-spiderMite{background:repeating-radial-gradient(circle at 40% 40%,rgba(202,142,80,.95) 0 1px,transparent 1.5px 8px)}.condition-scale{background:radial-gradient(circle at 25% 38%,#d5c2a3 0 3px,transparent 3.5px),radial-gradient(circle at 60% 55%,#c7ad89 0 3px,transparent 3.5px),radial-gradient(circle at 75% 24%,#dfcfb2 0 2.5px,transparent 3px)}.deadwood-mark{position:absolute;width:64px;height:11px;transform:translate(-48%,-50%) rotate(-16deg);border-radius:80% 10% 70% 20%;background:linear-gradient(90deg,#d5c49c,#f0e4c8 52%,#908061);box-shadow:0 1px 3px #0008}.wire-layer{position:absolute;inset:0;z-index:4;width:100%;height:100%;pointer-events:none}.wire-path{fill:none;stroke:#ac7447;stroke-width:.65;stroke-linecap:round;stroke-dasharray:1.6 1.2;filter:drop-shadow(0 .5px .4px #000)}.wire-strong{stroke-width:1}.shari-path{fill:none;stroke:#d4c49f;stroke-width:1.25;stroke-linecap:round;opacity:.82;filter:drop-shadow(0 1px .6px #000)}.shari-2{stroke-width:2}.shari-3{stroke-width:3}.part-hotspot{position:absolute;z-index:8;transform:translate(-50%,-50%);width:32px;height:32px;border:1px solid rgba(242,235,220,.55);border-radius:50%;background:rgba(7,16,11,.75);color:var(--cream);font-size:10px;box-shadow:0 3px 14px #0008}.part-hotspot.selected{background:var(--gold);color:#12160f;border-color:#f2e1b6;transform:translate(-50%,-50%) scale(1.12)}.metric-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:7px;padding:10px}.metric{position:relative;overflow:hidden;border:1px solid var(--line);border-radius:14px;background:rgba(5,11,7,.74);padding:9px;text-align:center}.metric b{display:block;font-size:16px}.metric span{color:var(--muted);font-size:9px}.metric i{position:absolute;bottom:0;left:0;height:2px;background:var(--gold)}.action-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:7px;padding:0 10px 12px}.action-grid button{border:1px solid var(--line);border-radius:14px;background:rgba(255,255,255,.035);color:var(--cream);padding:10px 3px;font-size:9px}.action-grid button span{display:block;font-size:21px;margin-bottom:3px}.mentor-card{display:grid;grid-template-columns:47px 1fr;gap:12px;align-items:center;margin:11px 0;padding:13px;border-left:2px solid var(--gold);background:rgba(214,183,119,.075);border-radius:4px 16px 16px 4px}.mentor-avatar{width:47px;height:47px;border-radius:50%;display:grid;place-items:center;background:#755440;font-size:26px}.mentor-card b{font-size:12px}.mentor-card p{color:#b7c0b9;font:12px Georgia,serif;line-height:1.6;margin:4px 0 0}.secondary-actions{display:grid;grid-template-columns:1fr 1fr;gap:8px}.secondary-actions button{border:1px solid var(--line);border-radius:15px;background:var(--panel);color:var(--cream);padding:13px}.stats-row{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-top:9px}.stats-row>div{border:1px solid var(--line);border-radius:17px;background:var(--panel);padding:12px}.stats-row small{display:block;color:var(--muted);font-size:9px}.stats-row b{display:block;color:var(--gold);font:23px Georgia,serif;margin-top:4px}.alert-card{display:grid;gap:6px;margin-top:10px;border:1px solid rgba(166,81,70,.45);border-radius:17px;background:rgba(166,81,70,.1);padding:13px}.alert-card b{font-size:12px}.alert-card span{color:#d7b8b1;font-size:10px}.alert-card button{justify-self:start;border:0;border-radius:10px;background:#a65146;color:white;padding:8px 11px;font-size:10px}.pot-list,.people-list{display:grid;gap:9px}.pot-card{display:grid;grid-template-columns:110px 1fr auto;gap:12px;align-items:center;border:1px solid var(--line);border-radius:20px;background:var(--panel);padding:12px}.pot-card.active{border-color:rgba(214,183,119,.58);box-shadow:inset 0 0 0 1px rgba(214,183,119,.16)}.pot-preview{height:74px;display:grid;place-items:center;background:radial-gradient(ellipse,#46604a33,transparent 65%)}.pot-preview span{display:block;width:96px;height:37px;border-radius:5px 5px 22px 22px;background:var(--pot);box-shadow:inset 0 6px 8px #fff2,inset 0 -8px 12px #0004,0 12px 17px #0007}.pot-copy b{display:block}.pot-copy small{color:var(--gold);font-size:9px}.pot-copy p{color:var(--muted);font-size:10px