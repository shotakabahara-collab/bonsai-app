;line-height:1.55;margin:5px 0 0}.pot-card>button{border:1px solid var(--line);border-radius:12px;background:rgba(255,255,255,.045);color:var(--cream);padding:9px;font-size:9px}.show-card>.bonsai-stage{height:310px}.show-score{display:flex;align-items:end;justify-content:space-between;padding:15px 17px 6px}.show-score small{color:var(--muted)}.show-score b{font:44px Georgia,serif;color:var(--gold)}.show-score b span{font-size:12px;margin-left:4px}.show-card ul,.result-card ul{color:#b6c0b8;font-size:11px;line-height:1.65;padding:0 29px;margin:5px 0 14px}.primary-button,.ghost-button{width:100%;border-radius:14px;padding:14px 16px;font-weight:750}.primary-button{border:0;background:var(--cream);color:#11170f}.show-card>.primary-button{width:calc(100% - 24px);margin:0 12px 13px}.ghost-button{border:1px solid var(--line);background:transparent;color:var(--cream);margin-top:8px}.latest-award{display:grid;grid-template-columns:48px 1fr;gap:11px;margin-top:10px;border:1px solid var(--line);border-radius:19px;background:var(--panel);padding:13px}.latest-award>span{font-size:34px}.latest-award small{display:block;color:var(--muted);font-size:9px}.latest-award b{display:block}.latest-award p{color:var(--muted);font-size:9px;margin:5px 0 0}.people-list article{display:grid;grid-template-columns:64px 1fr;gap:13px;border:1px solid var(--line);border-radius:20px;background:var(--panel);padding:14px}.people-list article.mentor-active{border-color:rgba(214,183,119,.55)}.person-face{width:64px;height:64px;border-radius:50%;display:grid;place-items:center;background:linear-gradient(145deg,#9c735d,#53392e);font-size:35px}.people-list small{color:var(--gold);font-size:9px}.people-list h2{font:21px Georgia,serif;margin:3px 0}.people-list h2 em{font:normal 8px sans-serif;border:1px solid rgba(214,183,119,.45);border-radius:99px;padding:3px 6px;margin-left:7px;color:var(--gold)}.people-list p{color:#b8c1ba;font:12px Georgia,serif;line-height:1.55;margin:3px 0}.relationship{display:inline-block;margin-top:4px;border-radius:99px;padding:4px 7px;font-size:8px}.rival{background:#7c3c3322;color:#e0a99e}.judge{background:#b18d4f22;color:#e3c78e}.critic{background:#476a7622;color:#a9ccd8}.wealthy{background:#775f9222;color:#c5b1d9}.memorial-button{margin-bottom:10px}.memorial-hero{overflow:hidden;border:1px solid var(--line);border-radius:22px;background:var(--panel)}.memorial-hero .bonsai-stage{height:300px}.memorial-hero>div{padding:13px}.memorial-hero b{display:block}.memorial-hero span{display:block;color:#5e6c61;font:8px monospace;overflow:hidden;white-space:nowrap;text-overflow:ellipsis;margin-top:5px}.timeline{position:relative;margin:16px 0 0 11px;padding-left:25px;border-left:1px solid #ffffff16}.timeline article{position:relative;padding:0 0 19px}.timeline-dot{position:absolute;left:-31px;top:3px;width:11px;height:11px;border-radius:50%;background:#5c6c61;border:2px solid var(--bg)}.timeline-dot.award{background:var(--gold)}.timeline-dot.memory{background:#739b7d}.timeline time{display:block;color:#68766d;font-size:8px}.timeline b{display:block;font-size:11px;margin-top:3px}.timeline p{color:var(--muted);font-size:9px;margin:4px 0}.empty{color:var(--muted)}.bottom-nav{position:fixed;z-index:30;bottom:0;left:0;right:0;display:grid;grid-template-columns:repeat(5,1fr);padding:7px 7px calc(7px + env(safe-area-inset-bottom));border-top:1px solid var(--line);background:rgba(5,12,8,.92);backdrop-filter:blur(18px)}.bottom-nav button{border:0;background:transparent;color:#7f8d83;padding:4px 2px;font-size:9px}.bottom-nav button span{display:block;font-size:20px;margin-bottom:2px}.bottom-nav button.active{color:var(--cream)}.care-overlay,.modal-backdrop{position:fixed;z-index:80;inset:0;background:rgba(0,0,0,.76);display:flex;align-items:flex-end}.care-sheet{width:min(100%,760px);max-height:94vh;margin:auto;overflow:auto;border-radius:26px 26px 0 0;background:#0f1b14;border:1px solid var(--line);padding:15px 14px calc(20px + env(safe-area-inset-bottom))}.care-sheet header{display:flex;align-items:flex-start;justify-content:space-between;padding:2px 2px 11px}.care-sheet h2{font:27px Georgia,serif;margin:4px 0}.care-sheet header>button{border:1px solid v