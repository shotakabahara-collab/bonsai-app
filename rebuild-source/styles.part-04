ist>button>span{font-size:34px}.mentor-list b,.mentor-list small,.mentor-list em{display:block}.mentor-list small{color:var(--gold);font-size:8px}.mentor-list em{color:#b9c2bb;font:11px Georgia,serif;margin-top:4px}.onboard-panel label{display:block;color:var(--muted);font-size:10px;margin:14px 0}.onboard-panel input{display:block;width:100%;margin-top:7px;border:1px solid var(--line);border-radius:14px;background:#ffffff08;color:var(--cream);padding:13px}.fatal-screen section{margin-top:40px;border:1px solid var(--line);border-radius:22px;background:var(--panel);padding:21px}.fatal-screen pre{white-space:pre-wrap;color:#956c65;font-size:8px}.fatal-screen button{width:100%;border:0;border-radius:14px;background:var(--cream);color:#101610;padding:14px;font-weight:700}@media(max-width:520px){.bonsai-stage{height:340px}.pot-card{grid-template-columns:93px 1fr}.pot-card>button{grid-column:1/-1}.people-list article{grid-template-columns:55px 1fr}.person-face{width:55px;height:55px}.three-buttons{grid-template-columns:1fr}.care-stage{height:315px}}@media(prefers-reduced-motion:reduce){*{animation-duration:.01ms!important;transition-duration:.01ms!important}}
